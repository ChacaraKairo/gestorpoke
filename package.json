{
  "name": "gestorpoke",
  "version": "0.1.0",
  "private": true,
  "description": "Assistente desktop para organizar Pokémon, builds, equipes e estratégias.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-vite": "5.0.0",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "7.3.6",
    "vitest": "latest"
  },
  "build": {
    "appId": "br.com.chacarakairo.gestorpoke",
    "productName": "GestorPoke",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Game"
    },
    "win": {
      "target": ["nsis"]
    }
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
